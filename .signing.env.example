# Local signing config for macOS app builds.
# Copy this file to .signing.env and fill in your own values.

SIGN_IDENTITY="Apple Distribution: YOUR COMPANY NAME (TEAMID1234)"
# Optional: override the bundle identifier used during signing.
# BUNDLE_ID="com.example.PixelClaw"

# Optional: point to an entitlements plist.
# ENTITLEMENTS="/absolute/path/to/PixelClaw.entitlements"
